    "@rankforge-root/edge": "*",
    "@rankforge-root/hydration": "*",
    "@rankforge-root/i18n": "*",
    "@rankforge-root/images": "*",
    "@rankforge-root/meta": "*",
    "@rankforge-root/monitor": "*",
    "@rankforge-root/performance": "*",
    "@rankforge-root/schema": "*",
    "@rankforge-root/security": "*",
    "@rankforge-root/sitemap": "*"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
